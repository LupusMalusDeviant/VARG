{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Varg",
    "scopeName": "source.varg",
    "patterns": [
        { "include": "#comments" },
        { "include": "#multiline_strings" },
        { "include": "#interpolated_strings" },
        { "include": "#prompt_literal" },
        { "include": "#strings" },
        { "include": "#annotations" },
        { "include": "#keywords_control" },
        { "include": "#keywords_declaration" },
        { "include": "#builtins" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#numbers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.varg",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.varg",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "multiline_strings": {
            "name": "string.quoted.triple.varg",
            "begin": "\"\"\"",
            "end": "\"\"\"",
            "patterns": [
                {
                    "name": "variable.other.interpolation.varg",
                    "match": "\\{[^}]+\\}"
                }
            ]
        },
        "interpolated_strings": {
            "name": "string.quoted.double.interpolated.varg",
            "begin": "\\$\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "variable.other.interpolation.varg",
                    "match": "\\{[^}]+\\}"
                },
                {
                    "name": "constant.character.escape.varg",
                    "match": "\\\\."
                }
            ]
        },
        "prompt_literal": {
            "name": "string.quoted.triple.prompt.varg",
            "begin": "prompt\\s+\"\"\"",
            "end": "\"\"\"",
            "patterns": [
                {
                    "name": "variable.other.interpolation.varg",
                    "match": "\\{[^}]+\\}"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.varg",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.varg",
                    "match": "\\\\."
                }
            ]
        },
        "annotations": {
            "patterns": [
                {
                    "name": "entity.name.function.decorator.varg",
                    "match": "@\\[(?:[a-zA-Z_][a-zA-Z0-9_]*)(?:\\([^)]*\\))?\\]"
                }
            ]
        },
        "keywords_control": {
            "name": "keyword.control.varg",
            "match": "\\b(if|else|while|for|foreach|in|try|catch|throw|return|from|where|select|orderby|descending|import|match|retry|fallback|break|continue|unsafe|spawn|send|request)\\b"
        },
        "keywords_declaration": {
            "name": "keyword.other.varg",
            "match": "\\b(public|private|system|async|agent|contract|struct|enum|var|let|const|type|fn|prompt|self|new|override|implements|pub|print|on_start|on_stop|on_message)\\b"
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.varg",
                    "match": "\\b(fs_read|fs_write|fs_append|fs_read_lines|fs_read_dir|fs_read_bytes|fs_write_bytes|fs_append_bytes|fs_size|create_dir|delete_file|path_exists|path_join|path_parent|path_extension|path_stem)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(fetch|http_request|http_serve|http_route|http_listen|http_response|http_sse_route|sse_connect|sse_read|sse_close|sse_event)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(db_open|db_execute|db_query)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(ws_connect|ws_send|ws_receive|ws_close)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(mcp_connect|mcp_list_tools|mcp_call_tool|mcp_disconnect|mcp_server_new|mcp_server_register|mcp_server_run)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(llm_chat|llm_complete|llm_structured|llm_stream|llm_embed_batch|llm_vision)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(json_parse|json_get|json_get_int|json_get_bool|json_get_array|json_stringify)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(graph_open|graph_add_node|graph_add_edge|graph_query|graph_traverse|graph_neighbors)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(embed|vector_store_open|vector_store_upsert|vector_store_search|vector_store_delete|vector_store_count|cosine_sim|vector_build_index|vector_search_fast)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(memory_open|memory_set|memory_get|memory_store|memory_recall|memory_add_fact|memory_query_facts|memory_clear_working|memory_episode_count)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(trace_start|trace_span|trace_end|trace_error|trace_event|trace_set_attr|trace_export|trace_span_count)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(event_bus_new|event_on|event_emit|event_count|pipeline_new|pipeline_add_step|pipeline_run|pipeline_step_count)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(orchestrator_new|orchestrator_add_task|orchestrator_run_all|orchestrator_results|orchestrator_task_count|orchestrator_completed_count|fan_out|fan_in)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(self_improver_new|self_improver_record_success|self_improver_record_failure|self_improver_recall|self_improver_success_rate|self_improver_iterations|self_improver_stats)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(await_approval|await_input|await_choice)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(ratelimiter_new|ratelimiter_acquire|ratelimiter_try_acquire|rate_limit_acquire|rate_limit_try|rate_limit_reset)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(budget_new|budget_track|budget_check|budget_remaining_tokens|budget_remaining_usd_cents|budget_report|estimate_tokens)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(checkpoint_open|checkpoint_save|checkpoint_load|checkpoint_clear|checkpoint_exists|checkpoint_age)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(channel_new|channel_send|channel_recv|channel_try_recv|channel_recv_timeout|channel_len|channel_close|channel_is_closed)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(prop_gen_int|prop_gen_float|prop_gen_bool|prop_gen_string|prop_gen_int_list|prop_gen_string_list|prop_check|prop_assert)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(image_load|image_from_base64|image_to_base64|image_format|image_size_bytes|audio_load|audio_to_base64|audio_format|audio_size_bytes)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(workflow_new|workflow_add_step|workflow_set_output|workflow_set_failed|workflow_ready_steps|workflow_is_complete|workflow_get_output|workflow_step_count|workflow_status)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(registry_open|registry_install|registry_uninstall|registry_is_installed|registry_version|registry_list|registry_search)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(proc_spawn|proc_wait|proc_kill|proc_status)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(home_dir|config_dir|data_dir|cache_dir|config_load_cascade)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(readline_new|readline_read|readline_add_history|readline_load_history|readline_save_history)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(base64_encode|base64_decode|base64_encode_file|http_download_base64)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(pdf_create|pdf_add_section|pdf_add_text|pdf_save|pdf_to_base64)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(exec|exec_status|env|sleep|timestamp)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(time_millis|time_format|time_parse|time_add|time_diff)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(encrypt|decrypt)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(log_debug|log_info|log_warn|log_error)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(abs|sqrt|floor|ceil|round|min|max|pow|parse_int|parse_float)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(assert|assert_eq|assert_ne|assert_true|assert_false|assert_contains|assert_throws)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(regex_match|regex_find_all|regex_replace)\\b"
                },
                {
                    "name": "support.function.varg",
                    "match": "\\b(len|push|pop|remove|contains|sort|filter|map|find|any|all|keys|values|split|join|trim|to_upper|to_lower|starts_with|ends_with|replace|substring|index_of|pad_left|pad_right|char_at|chars|reverse|repeat)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.varg",
                    "match": "\\b(int|float|string|bool|void|ulong)\\b"
                },
                {
                    "name": "support.type.ai.varg",
                    "match": "\\b(Tensor|Prompt|Context|Embedding)\\b"
                },
                {
                    "name": "support.type.capability.varg",
                    "match": "\\b(FileAccess|NetworkAccess|DbAccess|LlmAccess|SystemAccess)\\b"
                },
                {
                    "name": "support.type.complex.varg",
                    "match": "\\b(Result|Error|List|map|set)\\b"
                },
                {
                    "name": "support.type.handle.varg",
                    "match": "\\b(GraphHandle|VectorStoreHandle|MemoryHandle|TracerHandle|EventBusHandle|PipelineHandle|OrchestratorHandle|SelfImproverHandle|BudgetHandle|CheckpointHandle|ChannelHandle|WorkflowHandle|RegistryHandle|RateLimiterHandle|ImageHandle|AudioHandle|SseHandle|DbHandle|WsHandle|McpHandle|McpServerHandle|ReadlineHandle|ProcHandle)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.varg",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.varg",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        }
    }
}
